<!DOCTYPE html>
<html lang="zh-HK">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scale=no, viewport-fit=cover">
    <title>鏡遇 Mirror</title>
    
    <!-- 引入日系柔和字體 -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600;700&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body, html {
            width: 100%;
            height: 100%;
            overflow: hidden;
            font-family: 'Noto Serif TC', 'Times New Roman', serif;
            -webkit-tap-highlight-color: transparent;
            background-color: #f5f0eb; /* 備用背景 */
        }

        /* 背景層：永遠固定，永遠覆蓋，永遠不動 */
        .bg-layer {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('background.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed; /* 雙重保險 */
            z-index: -1;
        }

        /* 內容容器：撐滿螢幕，置中對齊 */
        .container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* 頁面卡片：磨砂玻璃效果 */
        .page {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
            padding: 2rem;
            text-align: center;
            color: #3e3a37;
            backdrop-filter: blur(2px); /* 極輕微的模糊，保持文字清晰 */
            transition: opacity 0.6s ease, visibility 0.6s ease;
        }

        .page.active {
            display: flex;
            opacity: 1;
        }

        /* 內部文字區塊，加上半透明白色底提升可讀性 */
        .content-box {
            background: rgba(255, 255, 255, 0.55);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-radius: 32px;
            padding: 2.5rem 2rem;
            max-width: 480px;
            width: 90%;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08), 0 0 0 1px rgba(255, 255, 255, 0.6);
            animation: fadeInUp 0.8s ease-out;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        h1 {
            font-size: clamp(2.8rem, 10vw, 4.5rem);
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: #5b4c44;
            letter-spacing: 0.05em;
            text-shadow: 0 2px 15px rgba(255,255,255,0.8);
        }

        .subtitle {
            font-size: clamp(1.1rem, 4vw, 1.4rem);
            font-weight: 600;
            margin-bottom: 0.25rem;
            color: #6b5e53;
            letter-spacing: 0.08em;
        }

        .english {
            font-family: 'Georgia', 'Times New Roman', serif;
            font-size: clamp(1rem, 3.5vw, 1.2rem);
            font-weight: 400;
            margin-bottom: 1.8rem;
            color: #88807a;
            letter-spacing: 0.15em;
            text-transform: uppercase;
        }

        .description {
            font-size: clamp(0.95rem, 3.5vw, 1.1rem);
            line-height: 1.8;
            margin-bottom: 2.2rem;
            color: #4d453f;
            font-weight: 400;
        }

        .small-note {
            font-size: 0.85rem;
            color: #8b8178;
            margin-bottom: 2rem;
            letter-spacing: 0.08em;
        }

        /* 霧面圓角按鈕 */
        .btn-matte {
            display: inline-block;
            padding: 0.9rem 2.8rem;
            background: rgba(255, 255, 255, 0.45);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.8);
            border-radius: 60px;
            font-size: 1.2rem;
            font-weight: 600;
            color: #4d453f;
            letter-spacing: 0.12em;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06), 0 0 0 1px rgba(255,255,255,0.4) inset;
            text-decoration: none;
            font-family: 'Noto Serif TC', serif;
        }

        .btn-matte:hover {
            background: rgba(255, 255, 255, 0.65);
            border-color: rgba(255, 255, 255, 1);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1), 0 0 0 1px rgba(255,255,255,0.6) inset;
            transform: translateY(-2px);
        }

        .btn-matte:active {
            transform: translateY(0);
            background: rgba(255, 255, 255, 0.7);
            transition: 0.05s;
        }

        /* 第二頁特別樣式 */
        .success-icon {
            font-size: 3rem;
            margin-bottom: 0.5rem;
            color: #7b8d7b;
            filter: drop-shadow(0 4px 8px rgba(0,0,0,0.05));
        }

        .page-title {
            font-size: clamp(2.2rem, 8vw, 3rem);
            font-weight: 700;
            margin-bottom: 0.8rem;
            color: #5b4c44;
        }
    </style>
</head>
<body>
    <!-- 固定背景圖層，完全不會移動 -->
    <div class="bg-layer" aria-hidden="true"></div>

    <!-- 頁面1：首頁 -->
    <div class="container">
        <div class="page active" id="page1">
            <div class="content-box">
                <h1>鏡遇 Mirror</h1>
                <div class="subtitle">一場關於理解、共情與改變的旅程</div>
                <div class="english">Experience · Empathize · Equalize</div>
                <div class="description">
                    這是一款全新的性別體驗互換劇情類遊戲，<br>邊遊玩劇情，深入認識SDG5性別平等理念
                </div>
                <div class="small-note">遊戲研發中，敬請期待</div>
                <button class="btn-matte" id="reserveBtn">點擊預約</button>
            </div>
        </div>

        <!-- 頁面2：預約成功 -->
        <div class="page" id="page2">
            <div class="content-box">
                <div class="success-icon">✉️</div>
                <div class="page-title">預約成功</div>
                <div class="description" style="margin-bottom: 1rem;">
                    開服上線我們將會以簡訊通知您
                </div>
                <div class="small-note" style="margin-bottom: 0;">靜待相逢，敬請期待</div>
            </div>
        </div>
    </div>

    <script>
        // 頁面切換功能
        const page1 = document.getElementById('page1');
        const page2 = document.getElementById('page2');
        const reserveBtn = document.getElementById('reserveBtn');

        // 點擊預約按鈕時，流暢切換到第二頁
        reserveBtn.addEventListener('click', function() {
            // 第一頁淡出
            page1.style.opacity = '0';
            page1.style.transition = 'opacity 0.5s ease, visibility 0s 0.5s';
            
            // 等待動畫結束後隱藏第一頁，顯示第二頁
            setTimeout(() => {
                page1.classList.remove('active');
                page1.style.opacity = '';
                page1.style.transition = '';
                
                // 第二頁淡入，先設定透明度0再顯示
                page2.style.opacity = '0';
                page2.classList.add('active');
                // 強制重繪
                void page2.offsetWidth;
                page2.style.transition = 'opacity 0.6s ease';
                page2.style.opacity = '1';
                
                // 清除行內樣式以免干擾後續
                setTimeout(() => {
                    page2.style.transition = '';
                    page2.style.opacity = '';
                }, 600);
            }, 500);
        });

        // 針對 iOS Safari 修正 backdrop-filter 可能不支援的情況，使用半透明背景補強
        // 已透過 rgba 背景確保沒有模糊時依然可讀
    </script>
</body>
</html>
